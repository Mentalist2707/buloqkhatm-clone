// BuloqKhatm - Global Qur'on Xatmi Platformasi
// Prisma Schema v3 — Telegram-First Auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum KhatmStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum KhatmType {
  GLOBAL
  PRIVATE
}

enum JuzStatus {
  AVAILABLE
  RESERVED
  COMPLETED
}

enum NotificationType {
  JUZ_DEADLINE
  KHATM_COMPLETED
  MODERATOR_MESSAGE
  NEW_KHATM
  SYSTEM
}

enum BadgeType {
  KHATM_1
  KHATM_10
  KHATM_50
  KHATM_100
  STREAK_7
  STREAK_30
  REFERRAL
}

/// BuloqCoin tranzaksiya sabablari
enum CoinReason {
  DAILY_ACTIVITY    // +5   — kunlik faollik
  PAGE_READ         // ichki — coin bermaydi
  JUZ_COMPLETED     // +25  — pora to'liq o'qildi
  KHATM_PARTICIPANT // +25  — xatm yakunlandi (ishtirokchi)
  KHATM_CREATOR     // +100 — xatm yaratuvchi bonus
  STREAK_7          // +20  — 7 kun streak
  STREAK_30         // +50  — 30 kun streak
  REFERRAL          // +15  — do'st taklif
  ADMIN_BONUS       // admin qo'shdi
  ADMIN_DEDUCT      // admin ayirdi
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id         String  @id @default(cuid())

  /// Telegram asosiy identifikator — UNIQUE, majburiy
  telegramId String  @unique @map("telegram_id")

  /// Telegram profil ma'lumotlari
  username   String?
  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  photoUrl   String? @map("photo_url")

  // NextAuth adapter uchun kerakli fieldlar
  name          String?   // firstName + lastName birlashmasi
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?   // photoUrl nusxasi

  role         Role    @default(USER)

  // BuloqCoin
  coins        Int     @default(0)
  level        String  @default("Beginner")
  streakDays   Int     @default(0)  @map("streak_days")
  lastActiveAt DateTime? @map("last_active_at")
  lastDailyAt  DateTime? @map("last_daily_at")

  // Statistika
  totalPagesRead Int @default(0) @map("total_pages_read")
  totalJuzRead   Int @default(0) @map("total_juz_read")
  totalKhatms    Int @default(0) @map("total_khatms")

  country      String?
  isActive     Boolean  @default(true)  @map("is_active")
  isBanned     Boolean  @default(false) @map("is_banned")
  bannedAt     DateTime? @map("banned_at")
  bannedReason String?   @map("banned_reason")
  referredBy   String?   @map("referred_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  khatmsCreated   Khatm[]           @relation("KhatmCreator")
  participations  Participation[]
  juzAssigned     Juz[]             @relation("JuzAssignee")
  juzProgress     JuzProgress[]
  notifications   Notification[]
  badges          UserBadge[]
  coinHistory     CoinTransaction[]
  dailyActivities DailyActivity[]
  joinRequests    JoinRequest[]
  referrals       User[]            @relation("Referrals")
  referrer        User?             @relation("Referrals", fields: [referredBy], references: [id])

  @@map("users")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Khatm ────────────────────────────────────────────────────────────────────

model Khatm {
  id            String      @id @default(cuid())
  title         String
  description   String?     @db.Text
  status        KhatmStatus @default(DRAFT)
  type          KhatmType   @default(GLOBAL)
  isPrivate     Boolean     @default(false) @map("is_private")
  inviteCode    String?     @unique @map("invite_code")
  startDate     DateTime?   @map("start_date")
  endDate       DateTime?   @map("end_date")
  completedAt   DateTime?   @map("completed_at")
  createdById   String      @map("created_by_id")
  maxJuzPerUser Int         @default(2)     @map("max_juz_per_user")
  requireSequential Boolean @default(false) @map("require_sequential")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt      @map("updated_at")

  createdBy      User            @relation("KhatmCreator", fields: [createdById], references: [id])
  juzList        Juz[]
  participations Participation[]
  joinRequests   JoinRequest[]

  @@map("khatms")
}

// ─── Juz (Pora) ───────────────────────────────────────────────────────────────

model Juz {
  id           String    @id @default(cuid())
  khatmId      String    @map("khatm_id")
  juzNumber    Int       @map("juz_number")
  totalPages   Int       @default(20) @map("total_pages")
  status       JuzStatus @default(AVAILABLE)
  assignedToId String?   @map("assigned_to_id")
  reservedAt   DateTime? @map("reserved_at")
  deadline     DateTime?
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  khatm      Khatm        @relation(fields: [khatmId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("JuzAssignee", fields: [assignedToId], references: [id])
  progress   JuzProgress?

  @@unique([khatmId, juzNumber])
  @@map("juz")
}

// ─── JuzProgress ─────────────────────────────────────────────────────────────

model JuzProgress {
  id         String   @id @default(cuid())
  juzId      String   @unique @map("juz_id")
  userId     String   @map("user_id")
  pagesRead  Int      @default(0) @map("pages_read")
  totalPages Int      @default(20) @map("total_pages")
  lastPageAt DateTime @default(now()) @map("last_page_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt      @map("updated_at")

  juz  Juz  @relation(fields: [juzId],  references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("juz_progress")
}

// ─── DailyActivity ────────────────────────────────────────────────────────────

model DailyActivity {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  pagesRead   Int      @default(0) @map("pages_read")
  juzRead     Int      @default(0) @map("juz_read")
  coinsEarned Int      @default(0) @map("coins_earned")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_activities")
}

// ─── Participation ────────────────────────────────────────────────────────────

model Participation {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  khatmId  String   @map("khatm_id")
  joinedAt DateTime @default(now()) @map("joined_at")
  juzCount Int      @default(0)     @map("juz_count")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  khatm Khatm @relation(fields: [khatmId], references: [id], onDelete: Cascade)

  @@unique([userId, khatmId])
  @@map("participations")
}

// ─── JoinRequest — private xatmga qo'shilish so'rovi ─────────────────────────

enum JoinRequestStatus {
  PENDING   // kutilmoqda
  APPROVED  // tasdiqlandi
  REJECTED  // rad etildi
}

model JoinRequest {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  khatmId   String            @map("khatm_id")
  status    JoinRequestStatus @default(PENDING)
  message   String?           // foydalanuvchi xabari (ixtiyoriy)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt      @map("updated_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  khatm Khatm @relation(fields: [khatmId], references: [id], onDelete: Cascade)

  @@unique([userId, khatmId])
  @@map("join_requests")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType @default(SYSTEM)
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── BuloqCoin Transaction ────────────────────────────────────────────────────

model CoinTransaction {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  amount      Int
  reason      CoinReason
  description String?
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coin_transactions")
}

// ─── Badges ───────────────────────────────────────────────────────────────────

model Badge {
  id          String    @id @default(cuid())
  type        BadgeType @unique
  name        String
  description String
  icon        String
  requirement Int
  createdAt   DateTime  @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}
